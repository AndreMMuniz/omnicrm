ENVIRONMENT=development
PORT=8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
WEBHOOK_BASE_URL=

# Local Docker Postgres only. Never point this file at production.
DATABASE_URL=postgresql://postgres:devpostgres@postgres:5432/chatmultichannel
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Local-only deterministic keys for safe dev bootstrapping.
DATABASE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
DATABASE_HMAC_KEY=local-dev-hmac-key

# Placeholder Supabase config so the app can initialize services that import it.
# Replace with a dedicated dev project only if you need real Auth/Storage flows locally.
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace-with-dev-anon-key-if-needed
SUPABASE_SERVICE_ROLE_KEY=

# Keep external integrations disabled in local Docker by default.
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
REDIS_URL=
