# =============================================================================
# Chat-multi-channel — Backend Environment Variables
# Copy this file to .env and fill in the values.
# .env is listed in .gitignore — NEVER commit the real .env file.
# =============================================================================

# ── Section 1: Database & Auth (Supabase) ────────────────────────────────────

# PostgreSQL connection string. Use Supabase pooler URL in production.
# type: str | required: yes
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# Supabase project URL.
# type: str | required: yes
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase public anon key (safe for client-side). Used for Auth flows.
# type: str | required: yes
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (admin privileges). Keep strictly secret.
# type: str | required: yes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SQLAlchemy base connection pool size.
# type: int | required: no | default: 20
DB_POOL_SIZE=20

# Burst connections above DB_POOL_SIZE. Total max = DB_POOL_SIZE + DB_MAX_OVERFLOW.
# type: int | required: no | default: 30
DB_MAX_OVERFLOW=30

# AES-256-GCM encryption key for channel credentials stored in the DB.
# Must be a 32-byte hex string (64 hex characters).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# In production, absence of this key causes the app to exit at startup.
# type: str | required: yes (production) / no (development — encryption skipped with warning)
DATABASE_ENCRYPTION_KEY=

# HMAC-SHA256 key used to hash email/phone for searchable lookup columns (email_hash, phone_hash).
# Without this, the app falls back to plain SHA-256 in dev — NEVER acceptable in production.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# type: str | required: yes (production) / no (development — plain SHA-256 fallback)
DATABASE_HMAC_KEY=


# ── Section 2: AI / LLM ──────────────────────────────────────────────────────

# OpenAI API key. Required for AI suggestions. Set this OR OPENROUTER_API_KEY.
# type: str | required: yes (one of OPENAI or OPENROUTER)
#OPENAI_API_KEY=sk-...

# OpenRouter API key. Alternative to OPENAI_API_KEY for model routing.
# config.py checks OPENROUTER_API_KEY first, then falls back to OPENAI_API_KEY — set only one.
# type: str | required: no (alternative to OPENAI_API_KEY)
# OPENROUTER_API_KEY=sk-or-v1-...

# LLM model identifier passed to the AI provider.
# type: str | required: no | default: gpt-4o-mini
DEFAULT_AI_MODEL=gpt-4o-mini

# LLM routing provider. Accepted values: openrouter, openai.
# type: str | required: no | default: openrouter
DEFAULT_AI_PROVIDER=openrouter


# ── Section 3: Agent Behaviour ───────────────────────────────────────────────

# Number of recent messages fed to the agent as conversation context.
# type: int | required: no | default: 20
AGENT_CONTEXT_MESSAGES=20

# Message count at which the agent summarises conversation history to save tokens.
# type: int | required: no | default: 30
AGENT_SUMMARIZE_THRESHOLD=30

# Set to true to enable automatic agent replies. false = suggestions only.
# type: bool | required: no | default: false
AGENT_AUTO_REPLY=false

# Minimum confidence score (0.0–1.0) for an auto-reply to be sent.
# Ignored when AGENT_AUTO_REPLY=false.
# type: float | required: no | default: 0.9
AGENT_AUTO_REPLY_CONFIDENCE=0.9

# Number of parallel agent worker tasks.
# type: int | required: no | default: 4
WORKER_CONCURRENCY=4

# Maximum in-memory queue depth before backpressure is applied.
# type: int | required: no | default: 1000
WORKER_QUEUE_MAXSIZE=1000

# Redis Streams connection URL. If unset, falls back to asyncio.Queue (volatile, non-durable).
# Required for durable task queue across worker restarts.
# type: str | required: no | default: (asyncio.Queue fallback)
REDIS_URL=redis://localhost:6379/0

# Redis stream key for the agent task queue.
# type: str | required: no | default: agent_queue
REDIS_STREAM_KEY=agent_queue

# Redis consumer group name for worker coordination.
# type: str | required: no | default: workers
REDIS_CONSUMER_GROUP=workers

# Max consecutive Redis errors before a task is moved to the dead-letter queue.
# type: int | required: no | default: 3
REDIS_MAX_RETRIES=3


# ── Section 4: Channel — Telegram ────────────────────────────────────────────

# Telegram bot token obtained from @BotFather.
# type: str | required: if Telegram channel is active
TELEGRAM_BOT_TOKEN=1234567890:ABC-your-bot-token


# ── Section 5: Channel — WhatsApp ────────────────────────────────────────────

# WhatsApp app secret for HMAC webhook signature validation.
# Optional but strongly recommended in production.
# type: str | required: no
# WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# Note: WHATSAPP_API_TOKEN and WHATSAPP_BUSINESS_ID are stored in the
# GeneralSettings DB table via Admin → Settings UI — no env vars needed.


# ── Section 6: Channel — SMS (Twilio) ────────────────────────────────────────

# Shared mailbox address used by the platform for sending and receiving email.
# Example for current tests: test@munizandre.com
# type: str | required: if Email channel is active
EMAIL_ADDRESS=test@munizandre.com

# Password for the shared mailbox above.
# type: str | required: if Email channel is active
EMAIL_PASSWORD=your-mailbox-password

# IMAP server for inbound polling.
# For Hostinger Email, use imap.hostinger.com with SSL on port 993.
# type: str | required: if Email channel is active
EMAIL_IMAP_HOST=imap.hostinger.com

# IMAP port for inbound polling.
# type: int | required: if Email channel is active | default: 993
EMAIL_IMAP_PORT=993

# SMTP server for outbound email.
# For Hostinger Email, use smtp.hostinger.com with SSL/TLS.
# type: str | required: if Email channel is active
EMAIL_SMTP_HOST=smtp.hostinger.com

# SMTP port for outbound email.
# Hostinger commonly uses 465 (SSL) or 587 (TLS/STARTTLS).
# type: int | required: if Email channel is active | default: 587
EMAIL_SMTP_PORT=465

# Twilio account SID. If empty, SMS sending is silently disabled.
# type: str | required: if SMS channel is active
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio auth token.
# type: str | required: if SMS channel is active
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Originating phone number in E.164 format.
# type: str | required: if SMS channel is active
TWILIO_PHONE_NUMBER=+15551234567

# ── Section 7: Deployment & Runtime ──────────────────────────────────────────

# Runtime environment. "production" enables secure (HTTPS-only) cookies.
# Any other value = development mode with relaxed cookie settings.
# type: str | required: no | default: development
ENVIRONMENT=development

# Frontend public URL. Used in password-reset email links.
# type: str | required: no | default: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Public base URL of this backend, used for Telegram webhook registration.
# Leave empty in local dev (Telegram webhook won't be auto-registered).
# Example production value: https://your-app.railway.app
# type: str | required: no (required for Telegram webhooks in production)
WEBHOOK_BASE_URL=

# Comma-separated list of allowed CORS origins.
# If empty, defaults to http://localhost:3000 in development.
# Example: https://your-app.vercel.app,https://your-custom-domain.com
# type: str | required: no | default: (localhost:3000)
ALLOWED_ORIGINS=

# HTTP server port. Railway sets this automatically in production.
# type: int | required: no | default: 8000
PORT=8000


# ── Section 8: Operational Tuning ────────────────────────────────────────────

# How often the IMAP email poller checks for new inbound email (seconds).
# type: int | required: no | default: 60
EMAIL_POLL_INTERVAL_SECONDS=60

# How often the SLA background loop evaluates at-risk conversations (seconds).
# type: int | required: no | default: 120
SLA_CHECK_INTERVAL_SECONDS=120

# Minutes before a conversation without a first-response is flagged as SLA risk.
# type: int | required: no | default: 60
SLA_THRESHOLD_MINUTES=60

# Number of delivery failures within the alert window to trigger a manager alert.
# type: int | required: no | default: 5
DELIVERY_ALERT_THRESHOLD=5

# Sliding window (minutes) used to count delivery failures for threshold alerts.
# type: int | required: no | default: 10
DELIVERY_ALERT_WINDOW_MINUTES=10


# ── Section 9: Future / Reserved ─────────────────────────────────────────────
# No pending future vars — DATABASE_ENCRYPTION_KEY and REDIS_URL are now active
# (see Sections 1 and 3 respectively).
